# SEC EDGAR (free — no key required, but set your contact email per EDGAR fair-use policy)
EDGAR_USER_AGENT="Your Name your.email@example.com"

# FRED (free — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Groq (free tier — https://console.groq.com/keys)

# ── Market data ───────────────────────────────────────────────────────────────
# Uses yfinance by default. No API key required.

# ── GraphRAG working directory ────────────────────────────────────────────────

# Target fund CIK numbers to track (comma-separated SEC CIK identifiers)
# Bridgewater = 1350694
# Citadel = 1423053
# Pershing Square = 1336528
# Leopold's Situational Awareness = 0002045724
# Leopold's Situational Awareness = 2045724
# Renaissance Technologies = 1037389
TARGET_CIKS=1350694,1423053,1336528,0002045724,1037389

# Sector ETFs to use as institutional proxy signals
PROXY_ETFS=SMH,XLU,XLK,XLF,XLE,XLV,XLI,XLB,XLRE,XLC,XLY,XLP

# Model checkpoint directory
MODEL_DIR=./checkpoints

# Feature store path
FEATURE_STORE_PATH=./data/features.parquet
